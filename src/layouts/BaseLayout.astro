---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  robots?: string;
  canonical?: string;
}

const {
  title = 'A un toque legal — Firma de Abogados Santiago, Chile',
  description = 'Cisternas, Lorenzini & Saleh. Conocimiento jurídico de élite, entregado con la velocidad y precisión que su situación exige.',
  ogImage = '/og-default.jpg',
  robots,
  canonical,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://auntoquelegal.cl');
const canonicalURL = canonical ? new URL(canonical, siteUrl) : new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(ogImage, siteUrl);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {robots && <meta name="robots" content={robots} />}
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/Montserrat-Light.otf" as="font" type="font/otf" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/Montserrat-Black.otf" as="font" type="font/otf" crossorigin="anonymous" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <slot name="head" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-[#1E1E1E] focus:text-[#E0E0E0] focus:px-4 focus:py-2 focus:text-xs focus:tracking-wider"
    >
      Saltar al contenido
    </a>

    <slot />
  </body>
</html>
