---
import Logo from "../shared/Logo.astro";
import ContactForm from "../shared/ContactForm.astro";
import { contact } from "../../data/site";
---

<section
  class="fp-section bg-[#1E1E1E] relative"
  data-section="6"
  aria-hidden="true"
  id="s07-contact"
>
  <div class="overflow-y-auto md:overflow-hidden grid grid-cols-1 md:grid-cols-2 md:h-full" data-no-nav>

    <!-- Izquierda: info -->
    <div class="px-8 py-10 md:px-12 md:py-12 md:overflow-y-auto flex flex-col justify-between md:h-full">
      <!-- Contenido principal centrado -->
      <div class="md:my-auto">
        <Logo variant="dark" maxWidth={140} />

        <div class="mt-8 border-l-2 border-[#807662] pl-5 space-y-3">
          <p class="font-light text-[#C1B7A7] text-[0.85rem] leading-relaxed whitespace-pre-line">
            {contact.address}
          </p>
          <div>
            <a
              href={`tel:${contact.phone.replace(/\s/g, "")}`}
              class="inline font-light text-[#C1B7A7] text-[0.85rem] hover:text-[#E0E0E0] transition-colors"
              data-no-nav
            >
              {contact.phone}
            </a>
          </div>
          <div>
            <a
              href={`mailto:${contact.email}`}
              class="inline font-light text-[#C1B7A7] text-[0.85rem] hover:text-[#E0E0E0] transition-colors"
              data-no-nav
            >
              {contact.email}
            </a>
          </div>
        </div>

        <p class="mt-8 font-light italic text-[#C1B7A7] text-[0.85rem]">
          Respondemos en menos de 24 horas hábiles.
        </p>
      </div>

      <!-- Footer anclado abajo -->
      <div class="mt-auto pt-6 flex flex-col gap-2">
        <a
          href="/landing"
          class="inline-flex items-center gap-2 font-light text-[0.75rem] tracking-widest uppercase text-[#807662] hover:text-[#C1B7A7] transition-colors"
          data-no-nav
        >
          <span>Ver sitio completo</span>
          <span>&rarr;</span>
        </a>
        <p class="font-light text-[10px] text-[#807662]">
          &copy; 2026 A un toque legal &mdash; Cisternas, Lorenzini &amp; Saleh.
        </p>
      </div>
    </div>

    <!-- Derecha: formulario -->
    <div class="px-8 pb-10 pt-8 md:px-12 md:py-12 md:overflow-y-auto md:border-l border-t border-[#807662]/20 md:border-t-0 flex flex-col justify-center md:h-full">
      <ContactForm darkMode={true} />
    </div>

  </div>

</section>
