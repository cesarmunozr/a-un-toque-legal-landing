---
import Logo from "../shared/Logo.astro";
---

<section class="bg-[#E0E0E0] pt-32 pb-24 px-8 md:px-12 lg:px-20" id="inicio">
  <div class="max-w-4xl mx-auto">
    <Logo variant="sand" maxWidth={200} class="mb-12" />

    <h1
      class="font-black text-[#1E1E1E] leading-[0.92] tracking-tight text-[clamp(2.5rem,6vw,4.5rem)] max-w-3xl"
    >
      Abogados en Santiago.<br />
      Resolución legal de primer nivel, siempre a un toque.
    </h1>

    <p class="mt-8 font-light text-[#807662] text-[clamp(1rem,2vw,1.15rem)] max-w-2xl leading-relaxed">
      Cisternas, Lorenzini &amp; Saleh. Firma de abogados especializada en litigación civil,
      libre competencia, derecho laboral y familia. Atención directa, sin intermediarios,
      con respuesta en 24 horas hábiles.
    </p>

    <a
      href="#contacto"
      class="mt-10 inline-block border border-[#1E1E1E] text-[#1E1E1E] font-semibold text-sm tracking-[0.12em] uppercase px-10 py-4 hover:bg-[#1E1E1E] hover:text-[#E0E0E0] transition-all duration-300"
      style="min-height: 44px; display: inline-flex; align-items: center;"
    >
      Contactar ahora &rarr;
    </a>
  </div>
</section>
