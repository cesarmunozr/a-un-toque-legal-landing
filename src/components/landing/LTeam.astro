---
import { Image } from "astro:assets";
import { team } from "../../data/site";

import gonzaloImg from "../../assets/lawyers/gonzalo-cisternas.jpg";
import jpImg from "../../assets/lawyers/juan-pablo-lorenzini.jpg";
import danielaImg from "../../assets/lawyers/daniela-saleh.jpg";
import joseImg from "../../assets/lawyers/jose-tomas-eyzaguirre.jpg";
import marleneImg from "../../assets/lawyers/marlene-molero.jpg";

const lawyerImages: Record<string, ImageMetadata> = {
  "gonzalo-cisternas": gonzaloImg,
  "juan-pablo-lorenzini": jpImg,
  "daniela-saleh": danielaImg,
  "jose-tomas-eyzaguirre": joseImg,
  "marlene-molero": marleneImg,
};
---

<section class="bg-[#1E1E1E] py-24 px-8 md:px-12 lg:px-20" id="equipo">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-bold text-[#E0E0E0] text-[clamp(1.5rem,3vw,2rem)] mb-16 tracking-tight">
      El equipo.
    </h2>

    <div class="space-y-16">
      {
        team.map((member) => (
          <article class="grid grid-cols-1 md:grid-cols-[240px_1fr] gap-6 md:gap-10 pb-16 border-b border-[#807662]/30 last:border-b-0 last:pb-0">
            <div class="shrink-0">
              <Image
                src={lawyerImages[member.imageKey]!}
                alt={member.name}
                width={240}
                height={300}
                class="w-full object-cover aspect-[4/5] grayscale"
                loading="lazy"
              />
            </div>
            <div class="flex flex-col justify-start pt-2">
              <h3 class="font-semibold text-[#E0E0E0] text-[1.3rem] leading-snug">{member.name}</h3>
              <p class="font-light text-[#807662] text-[0.9rem] mt-1 tracking-wider uppercase text-[0.75rem]">
                {member.role}
              </p>
              <p class="mt-1 font-light text-[#807662] text-[0.75rem]">{member.university}</p>

              <p class="mt-6 font-light text-[#C1B7A7] text-[0.9rem] leading-relaxed">{member.bio}</p>

              <ul class="mt-6 space-y-2" role="list">
                {member.credentials.map((cred) => (
                  <li class="flex items-start gap-3">
                    <span class="text-[#807662] text-[0.7rem] mt-1 shrink-0">&mdash;</span>
                    <span class="font-light text-[#C1B7A7] text-[0.82rem] leading-snug">{cred}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
