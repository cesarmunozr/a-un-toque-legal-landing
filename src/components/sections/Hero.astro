---
---

<section
  id="hero"
  class="bg-paper min-h-[90vh] flex items-center pt-16 md:pt-20"
>
  <div class="px-6 md:px-12 lg:px-20 2xl:px-32 max-w-[120rem] mx-auto w-full py-20 md:py-28 lg:py-36">
    <div class="max-w-5xl">

      <!-- Pre-headline -->
      <p
        data-fade
        class="font-sans text-[11px] tracking-[0.3em] uppercase text-ink/55 mb-10 md:mb-14"
      >
        Cisternas, Lorenzini &amp; Saleh &ensp;·&ensp; Santiago, Chile
      </p>

      <!-- H1 -->
      <h1
        data-fade
        style="transition-delay: 80ms;"
        class="font-display text-[clamp(2.75rem,6.5vw,7rem)] leading-[0.92] tracking-tight text-ink mb-10 md:mb-14"
      >
        Resolución legal<br />
        de primer nivel.<br />
        <span class="text-ink/80">Siempre a un toque.</span>
      </h1>

      <!-- Subtext -->
      <p
        data-fade
        style="transition-delay: 160ms;"
        class="font-sans text-base md:text-lg leading-relaxed text-ink/55 max-w-lg mb-12 md:mb-16"
      >
        Conocimiento jurídico de élite, entregado con la velocidad
        y precisión que su situación exige.
      </p>

      <!-- CTAs -->
      <div
        data-fade
        style="transition-delay: 240ms;"
        class="flex flex-col sm:flex-row items-start gap-4 sm:gap-8"
      >
        <a
          href="#contacto"
          class="inline-flex items-center justify-center bg-ink text-paper font-sans text-[11px] tracking-[0.25em] uppercase px-8 py-4 hover:bg-gold transition-colors duration-300 min-h-[44px]"
        >
          Consulta directa
        </a>
        <a
          href="#como-trabajamos"
          class="inline-flex items-center font-sans text-[11px] tracking-[0.25em] uppercase text-ink/60 hover:text-ink transition-colors duration-200 min-h-[44px] gap-2"
        >
          <span>Cómo trabajamos</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <!-- Decorative bottom accent -->
    <div
      data-fade
      style="transition-delay: 360ms;"
      class="mt-24 md:mt-36 flex items-center gap-6"
    >
      <div class="w-10 h-px bg-gold"></div>
      <p class="font-sans text-[11px] tracking-[0.3em] uppercase text-ink/45">
        Derecho que se mueve a tu ritmo
      </p>
    </div>
  </div>
</section>
