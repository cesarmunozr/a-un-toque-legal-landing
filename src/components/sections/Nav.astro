---
const navLinks = [
  { label: 'Filosofía', href: '#diferenciadores' },
  { label: 'Áreas', href: '#areas' },
  { label: 'Clientes', href: '#clientes' },
  { label: 'Contacto', href: '#contacto' },
];
---

<!-- Fixed header — becomes opaque with gold border on scroll via JS + data-scrolled attr -->
<header
  data-nav
  class="fixed top-0 left-0 right-0 z-50 bg-paper transition-all duration-300 data-[scrolled]:border-b data-[scrolled]:border-gold/40"
  style="padding-left: env(safe-area-inset-left); padding-right: env(safe-area-inset-right);"
>
  <nav
    role="navigation"
    aria-label="Navegación principal"
    class="flex items-center justify-between px-6 md:px-12 lg:px-20 h-16 md:h-20 max-w-[120rem] mx-auto"
  >
    <!-- Wordmark -->
    <a
      href="/"
      class="flex-shrink-0"
      aria-label="A un toque legal — inicio"
    >
      <img
        src="/logos/logo_auntoquelegal.png"
        alt="A un toque legal"
        class="h-8 md:h-10 w-auto"
        width="160"
        height="40"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8 lg:gap-10" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-sans text-xs tracking-[0.2em] uppercase text-ink/60 hover:text-ink transition-colors duration-200 min-h-[44px] inline-flex items-center"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="#contacto"
          class="font-sans text-xs tracking-[0.2em] uppercase border border-ink text-ink px-5 py-3 hover:border-gold hover:text-gold transition-all duration-200 min-h-[44px] inline-flex items-center"
        >
          Consulta directa
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      data-nav-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
      class="md:hidden flex flex-col justify-center items-end gap-[5px] min-w-[44px] min-h-[44px] p-2 -mr-2"
    >
      <span class="block w-6 h-px bg-ink"></span>
      <span class="block w-6 h-px bg-ink"></span>
      <span class="block w-4 h-px bg-ink"></span>
    </button>
  </nav>
</header>

<!-- Mobile fullscreen menu overlay -->
<div
  id="mobile-menu"
  hidden
  class="fixed inset-0 z-40 bg-paper flex flex-col items-center justify-center gap-8"
  style="padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom);"
  role="dialog"
  aria-label="Menú de navegación"
>
  {navLinks.map((link) => (
    <a
      href={link.href}
      class="font-display text-4xl text-ink hover:text-gold transition-colors duration-200 min-h-[44px] inline-flex items-center"
    >
      {link.label}
    </a>
  ))}
  <a
    href="#contacto"
    class="font-sans text-xs tracking-[0.2em] uppercase border border-ink text-ink px-10 py-4 hover:border-gold hover:text-gold transition-all duration-200 mt-4 min-h-[44px] inline-flex items-center"
  >
    Consulta directa
  </a>
</div>
