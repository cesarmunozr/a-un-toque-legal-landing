---
import { contact } from '../../data/site';
---

<section
  id="contacto"
  class="bg-paper py-24 md:py-32 lg:py-40 border-t border-ink/8 scroll-mt-20"
>
  <div class="px-6 md:px-12 lg:px-20 2xl:px-32 max-w-[120rem] mx-auto">

    <!-- Section header -->
    <div class="mb-16 md:mb-20" data-fade>
      <p class="font-sans text-[11px] tracking-[0.3em] uppercase text-gold mb-4">
        Contacto
      </p>
      <h2 class="font-display text-[clamp(2rem,4vw,3.75rem)] leading-[1.05] text-ink">
        Hablemos.
      </h2>
    </div>

    <!-- Split layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Left: contact info -->
      <div data-fade>
        <!-- Gold-bordered highlight -->
        <div class="border-l-2 border-gold pl-6 mb-12">
          <p class="font-display italic text-xl md:text-2xl text-ink leading-relaxed">
            Respondemos en menos de 24 horas hábiles.
          </p>
        </div>

        <div class="space-y-8">
          <div>
            <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-ink/35 mb-2">
              Correo
            </p>
            <a
              href={`mailto:${contact.email}`}
              class="font-display text-lg text-ink hover:text-gold transition-colors duration-200"
            >
              {contact.email}
            </a>
          </div>

          <div>
            <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-ink/35 mb-2">
              Teléfono
            </p>
            <a
              href={`tel:${contact.phone.replace(/\s/g, '')}`}
              class="font-sans text-base tracking-wide text-ink hover:text-gold transition-colors duration-200"
            >
              {contact.phone}
            </a>
          </div>

          <div>
            <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-ink/35 mb-2">
              Dirección
            </p>
            <address class="not-italic font-display text-lg text-ink leading-relaxed whitespace-pre-line">
              {contact.address}
            </address>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div data-fade style="transition-delay: 120ms;">
        <form
          data-form="contact"
          action="#"
          method="post"
          class="space-y-8"
        >
          <!-- Nombre -->
          <div class="space-y-1.5">
            <label for="nombre" class="block font-sans text-[9px] tracking-[0.3em] uppercase text-ink/40">
              Nombre
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              minlength="2"
              maxlength="100"
              autocomplete="name"
              placeholder="Su nombre completo"
              class="block w-full bg-transparent border-0 border-b border-ink/20 py-3 font-sans text-sm text-ink placeholder:text-ink/25 focus:outline-none focus:border-ink transition-colors duration-200"
            />
          </div>

          <!-- Teléfono -->
          <div class="space-y-1.5">
            <label for="telefono" class="block font-sans text-[9px] tracking-[0.3em] uppercase text-ink/40">
              Teléfono
            </label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              autocomplete="tel"
              placeholder="+56 9 1234 5678"
              class="block w-full bg-transparent border-0 border-b border-ink/20 py-3 font-sans text-sm text-ink placeholder:text-ink/25 focus:outline-none focus:border-ink transition-colors duration-200"
            />
          </div>

          <!-- Email -->
          <div class="space-y-1.5">
            <label for="email" class="block font-sans text-[9px] tracking-[0.3em] uppercase text-ink/40">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder="su@correo.cl"
              class="block w-full bg-transparent border-0 border-b border-ink/20 py-3 font-sans text-sm text-ink placeholder:text-ink/25 focus:outline-none focus:border-ink transition-colors duration-200"
            />
          </div>

          <!-- Consulta -->
          <div class="space-y-1.5">
            <label for="consulta" class="block font-sans text-[9px] tracking-[0.3em] uppercase text-ink/40">
              Consulta
            </label>
            <textarea
              id="consulta"
              name="consulta"
              required
              minlength="10"
              maxlength="2000"
              rows="4"
              placeholder="Cuéntenos brevemente su situación..."
              class="block w-full bg-transparent border-0 border-b border-ink/20 py-3 font-sans text-sm text-ink placeholder:text-ink/25 focus:outline-none focus:border-ink transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-ink text-paper font-sans text-[11px] tracking-[0.25em] uppercase py-4 hover:bg-gold transition-colors duration-300 min-h-[44px]"
          >
            Enviar consulta
          </button>

          <!-- Disclaimer -->
          <p class="font-sans text-xs text-ink/30 leading-relaxed">
            La información proporcionada es confidencial y se utilizará
            exclusivamente para responder su consulta.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>
