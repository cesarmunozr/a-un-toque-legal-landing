---
import { practiceAreas } from '../../data/site';
---

<section
  id="areas"
  class="bg-ink py-24 md:py-32 lg:py-40 scroll-mt-20"
>
  <div class="px-6 md:px-12 lg:px-20 2xl:px-32 max-w-[120rem] mx-auto">

    <!-- Section header -->
    <div class="mb-16 md:mb-20" data-fade>
      <p class="font-sans text-[11px] tracking-[0.3em] uppercase text-gold mb-4">
        Áreas de práctica
      </p>
      <h2 class="font-display text-[clamp(2rem,4vw,3.75rem)] leading-[1.05] text-paper max-w-2xl">
        Lo que hacemos<br />excepcionalmente bien.
      </h2>
    </div>

    <!-- Area rows with gold dividers -->
    <div class="border-t border-gold/20">
      {practiceAreas.map((area, i) => (
        <div
          data-fade
          style={`transition-delay: ${i * 80}ms;`}
          class="group border-b border-gold/20 py-6 md:py-8 -mx-6 md:-mx-12 lg:-mx-20 2xl:-mx-32 px-6 md:px-12 lg:px-20 2xl:px-32 hover:bg-paper/[0.03] transition-colors duration-300 cursor-default"
        >
          <div class="flex items-center justify-between gap-6">
            <div class="flex items-start gap-6 md:gap-10 min-w-0">
              <span
                aria-hidden="true"
                class="font-sans text-[10px] text-gold/50 tracking-wider mt-2 w-6 flex-shrink-0"
              >
                {area.numeral}
              </span>
              <div class="min-w-0">
                <h3 class="font-display text-xl md:text-2xl lg:text-[1.75rem] text-paper group-hover:text-gold transition-colors duration-300 leading-tight mb-1.5">
                  {area.area}
                </h3>
                <p class="font-sans text-sm text-paper/40 leading-relaxed">
                  {area.description}
                </p>
              </div>
            </div>
            <span
              aria-hidden="true"
              class="text-gold/30 font-sans text-lg flex-shrink-0 group-hover:translate-x-1 group-hover:text-gold/70 transition-all duration-300"
            >
              →
            </span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
