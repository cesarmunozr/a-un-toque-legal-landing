---
import { differentiators } from '../../data/site';
---

<section
  id="diferenciadores"
  class="bg-paper py-24 md:py-32 lg:py-40 border-t border-ink/8 scroll-mt-20"
>
  <div class="px-6 md:px-12 lg:px-20 2xl:px-32 max-w-[120rem] mx-auto">

    <!-- Section header -->
    <div class="mb-16 md:mb-20" data-fade>
      <p class="font-sans text-[11px] tracking-[0.3em] uppercase text-gold mb-3">
        Por qué elegirnos
      </p>
    </div>

    <!-- Three columns -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-14 md:gap-8 lg:gap-16">
      {differentiators.map((item, i) => (
        <div
          data-fade
          style={`transition-delay: ${i * 100}ms;`}
          class="border-t border-ink/12 pt-8"
        >
          <p
            aria-hidden="true"
            class="font-display text-5xl md:text-6xl text-gold leading-none mb-8 select-none"
          >
            {item.numeral}
          </p>
          <h3 class="font-display text-xl md:text-2xl lg:text-[1.6rem] text-ink mb-4 leading-tight">
            {item.title}
          </h3>
          <p class="font-sans text-sm leading-relaxed text-ink/55">
            {item.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
