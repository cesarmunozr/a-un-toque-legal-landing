---
import { Image } from 'astro:assets';
import { testimonials } from '../../data/site';

import anfpImg from '../../assets/clients/anfp.png';
import betterfoodImg from '../../assets/clients/betterfood_chile.jpeg';
import clearchannelImg from '../../assets/clients/clearchannel_chile.png';
import comudefImg from '../../assets/clients/comudef_laflorida_municipalidad.jpg';
import globalchannelImg from '../../assets/clients/globalchannel_chile.png';

const clients = [
  { src: anfpImg,         alt: 'ANFP — Asociación Nacional de Fútbol Profesional', width: 180, height: 60 },
  { src: betterfoodImg,   alt: 'BetterFood Chile',                                  width: 140, height: 60 },
  { src: clearchannelImg, alt: 'Clear Channel Chile',                               width: 200, height: 60 },
  { src: comudefImg,      alt: 'COMUDEF — Municipalidad La Florida',                width: 200, height: 60 },
  { src: globalchannelImg,alt: 'Global Channel Chile',                              width: 160, height: 60 },
];

const industries = [
  'Deporte profesional',
  'Alimentación & FoodTech',
  'Publicidad exterior',
  'Sector público',
  'Medios & Distribución',
];
---

<section
  id="clientes"
  class="bg-paper py-24 md:py-32 lg:py-40 border-t border-ink/8 scroll-mt-20"
>
  <div class="px-6 md:px-12 lg:px-20 2xl:px-32 max-w-[120rem] mx-auto">

    <!-- Section header -->
    <div class="mb-16 md:mb-20" data-fade>
      <p class="font-sans text-[11px] tracking-[0.3em] uppercase text-gold mb-4">
        Clientes
      </p>
      <h2 class="font-display text-[clamp(2rem,4vw,3.75rem)] leading-[1.05] text-ink max-w-lg">
        Lo que dicen quienes<br />nos confían sus asuntos.
      </h2>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 md:gap-10 mb-24 md:mb-28">
      {testimonials.map((t, i) => (
        <div
          data-fade
          style={`transition-delay: ${i * 100}ms;`}
          class="flex flex-col"
        >
          <p
            aria-hidden="true"
            class="font-display text-6xl text-gold/25 leading-none select-none -mb-2"
          >
            &ldquo;
          </p>
          <blockquote class="font-display italic text-[1.15rem] md:text-xl leading-relaxed text-ink mb-8 flex-1">
            {t.quote}
          </blockquote>
          <footer class="border-t border-ink/10 pt-5">
            <p class="font-sans text-[10px] tracking-[0.2em] uppercase text-ink font-medium">
              {t.author}
            </p>
            <p class="font-sans text-xs text-ink/40 mt-0.5">{t.role}</p>
          </footer>
        </div>
      ))}
    </div>

    <!-- Client logo strip -->
    <div class="border-t border-ink/8 pt-12" data-fade>
      <p class="font-sans text-[10px] tracking-[0.3em] uppercase text-ink/35 mb-10 text-center">
        Empresas e instituciones que confían en nosotros
      </p>

      <!-- Logos -->
      <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-8 md:gap-x-16 mb-12">
        {clients.map((client) => (
          <Image
            src={client.src}
            alt={client.alt}
            width={client.width}
            height={client.height}
            class="h-10 w-auto object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-400"
            loading="lazy"
            decoding="async"
            format="webp"
            quality={85}
          />
        ))}
      </div>

      <!-- Industries -->
      <p class="font-sans text-[10px] tracking-[0.25em] uppercase text-ink/25 text-center">
        {industries.join('\u2003·\u2003')}
      </p>
    </div>

  </div>
</section>
