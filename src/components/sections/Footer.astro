---
import { contact } from '../../data/site';

const navLinks = [
  { label: 'Filosofía', href: '#diferenciadores' },
  { label: 'Áreas', href: '#areas' },
  { label: 'Clientes', href: '#clientes' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="bg-ink py-16 md:py-20">
  <div
    class="px-6 md:px-12 lg:px-20 2xl:px-32 max-w-[120rem] mx-auto"
    style="padding-bottom: env(safe-area-inset-bottom);"
  >

    <!-- Top row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-14 md:mb-16">

      <!-- Wordmark + tagline -->
      <div>
        <img
          src="/logos/logo_auntoquelegal.png"
          alt="A un toque legal"
          class="h-8 w-auto mb-5 invert opacity-80"
          width="160"
          height="40"
          loading="lazy"
          decoding="async"
        />
        <p class="font-sans text-xs text-paper/55 leading-relaxed">
          Cisternas, Lorenzini &amp; Saleh<br />
          Abogados · Santiago de Chile
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-gold/70 mb-5">
          Navegación
        </p>
        <ul class="space-y-2.5" role="list">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-sans text-sm text-paper/55 hover:text-paper/80 transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-sans text-[9px] tracking-[0.3em] uppercase text-gold/70 mb-5">
          Contacto
        </p>
        <div class="space-y-2.5">
          <a
            href={`mailto:${contact.email}`}
            class="block font-sans text-sm text-paper/55 hover:text-paper/80 transition-colors duration-200"
          >
            {contact.email}
          </a>
          <a
            href={`tel:${contact.phone.replace(/\s/g, '')}`}
            class="block font-sans text-sm text-paper/55 hover:text-paper/80 transition-colors duration-200"
          >
            {contact.phone}
          </a>
          <address class="not-italic font-sans text-sm text-paper/45 leading-relaxed whitespace-pre-line">
            {contact.address}
          </address>
        </div>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="border-t border-paper/10 pt-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <p class="font-sans text-[10px] text-paper/40 tracking-wide">
        © 2026 A un toque legal — Cisternas, Lorenzini &amp; Saleh.
        Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a
          href="/privacidad"
          class="font-sans text-[10px] text-paper/40 hover:text-paper/65 transition-colors duration-200"
        >
          Política de privacidad
        </a>
        <a
          href="/terminos"
          class="font-sans text-[10px] text-paper/40 hover:text-paper/65 transition-colors duration-200"
        >
          Términos
        </a>
      </div>
    </div>

  </div>
</footer>
